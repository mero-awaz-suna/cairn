# Cairn API — Environment Variables
# Copy this to .env and fill in your values

# Supabase (required)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...your-service-role-key

# Google Gemini (required for linguistic extraction)
GOOGLE_API_KEY=your-gemini-api-key

# Legacy (can be removed once fully migrated to Supabase auth)
JWT_SECRET=not-used-anymore
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
