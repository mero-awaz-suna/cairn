# Required: Supabase backend connection
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required: JWT settings for app auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Optional: Journal transcription (leave blank to disable Groq transcription)
GROQ_API_KEY=

# Optional: Gemini / Google API key for linguistic extraction
GOOGLE_API_KEY=

# Optional: helper script settings (generate_token.py)
CAIRN_BASE_URL=http://127.0.0.1:8000
TEST_EMAIL=test.user@example.com
TEST_PASSWORD=change_me
USE_SUPABASE_AUTH=false
